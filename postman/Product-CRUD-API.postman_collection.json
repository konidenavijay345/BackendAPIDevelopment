{
  "info": {
    "name": "User JWT Product CRUD API",
    "description": "Register or login first. Product operations are JWT-protected and scoped to the authenticated user.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "userEmail", "value": "" },
    { "key": "userPassword", "value": "Password@123" },
    { "key": "jwtToken", "value": "" },
    { "key": "productId", "value": "1" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register user",
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": ["pm.collectionVariables.set('userEmail', 'vijay.' + Date.now() + '@example.com');"] }
            },
            {
              "listen": "test",
              "script": { "exec": [
                "pm.test('User registered', () => pm.response.to.have.status(201));",
                "if (pm.response.code === 201) pm.collectionVariables.set('jwtToken', pm.response.json().token);"
              ] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Vijay\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login user",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Login successful', () => pm.response.to.have.status(200));",
              "if (pm.response.code === 200) pm.collectionVariables.set('jwtToken', pm.response.json().token);"
            ] }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        }
      ]
    },
    {
      "name": "Products",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{jwtToken}}", "type": "string" }] },
      "item": [
        {
          "name": "Create product",
          "event": [{
            "listen": "test",
            "script": { "exec": [
              "pm.test('Created', () => pm.response.to.have.status(201));",
              "if (pm.response.code === 201) pm.collectionVariables.set('productId', pm.response.json().id);"
            ] }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"sku\": \"KEY-{{$timestamp}}\",\n  \"description\": \"Owned by the logged-in user\",\n  \"price\": 89.99,\n  \"quantity\": 25\n}" },
            "url": "{{baseUrl}}/api/v1/products"
          }
        },
        { "name": "List my products", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/products?page=0&size=20&sort=id,asc" } },
        { "name": "Get my product", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/products/{{productId}}" } },
        {
          "name": "Update my product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Mechanical Keyboard Pro\",\n  \"sku\": \"KEY-UPDATED-001\",\n  \"description\": \"Updated by its owner\",\n  \"price\": 99.99,\n  \"quantity\": 30\n}" },
            "url": "{{baseUrl}}/api/v1/products/{{productId}}"
          }
        },
        { "name": "Delete my product", "request": { "method": "DELETE", "url": "{{baseUrl}}/api/v1/products/{{productId}}" } }
      ]
    },
    { "name": "Health check", "request": { "method": "GET", "url": "{{baseUrl}}/actuator/health" } }
  ]
}
